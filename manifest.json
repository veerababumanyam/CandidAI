{
  "manifest_version": 3,
  "name": "CandidAI",
  "version": "0.0.3",
  "description": "AI-powered interview assistant for job seekers",
  "icons": {
    "16": "icons/logos/logo5.png",
    "48": "icons/logos/logo4.png",
    "128": "icons/logos/logo3.png"
  },
  "action": {
    "default_title": "CandidAI",
    "default_icon": {
      "16": "icons/logos/logo5.png",
      "48": "icons/logos/logo4.png",
      "128": "icons/logos/logo3.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "options_page": "src/options/options.html",
  "permissions": [
    "storage",
    "sidePanel",
    "notifications",
    "scripting",
    "activeTab",
    "offscreen"
  ]
}
